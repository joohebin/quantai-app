<script>
  // SW 仅在生产部署时启用，本地开发关闭以避免缓存干扰
  if('serviceWorker' in navigator && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1'){
    window.addEventListener('load', ()=>{
      navigator.serviceWorker.register('/sw.js')
        .then(()=>console.log('[PWA] Service Worker 注册成功'))
        .catch(e=>console.warn('[PWA] SW 注册失败:', e));
    });
  }
  // 本地开发：主动注销旧的 SW 和清除缓存
  if(location.hostname === 'localhost' || location.hostname === '127.0.0.1'){
    if('serviceWorker' in navigator){
      navigator.serviceWorker.getRegistrations().then(regs=>{
        regs.forEach(r=>r.unregister());
      });
    }
    if('caches' in window){
      caches.keys().then(keys=>keys.forEach(k=>caches.delete(k)));
    }
  }
</script>
<script src="https://unpkg.com/lightweight-charts@4.1.3/dist/lightweight-charts.standalone.production.js"></script>
<style>
/* ===== CSS 变量 & 重置 ===== */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --green:#00C896;--dark:#0A1628;--card:#111F35;--card2:#0D1A2D;
  --border:#1E3050;--text:#E8F4FF;--muted:#6B8DB0;
  --red:#FF4B6E;--yellow:#FFB800;--blue:#3B82F6;--purple:#A855F7;
  --sidebar:240px;--nav-h:64px;
}
html,body{height:100%;background:var(--dark);color:var(--text);font-family:-apple-system,'PingFang SC','Segoe UI',sans-serif;overflow:hidden}

/* ===== 滚动条 ===== */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}

/* ===== 布局骨架 ===== */
#app{display:flex;height:100vh;width:100vw;overflow:hidden}

/* 侧边栏（桌面/iPad横屏） */
#sidebar{
  width:var(--sidebar);flex-shrink:0;background:var(--card2);
  border-right:1px solid var(--border);display:flex;flex-direction:column;
  padding:0 0 20px;overflow:hidden;transition:width .3s;z-index:100;
}
/* RTL: 侧边栏在右侧，改 border 方向 */
[dir=rtl] #sidebar{border-right:none;border-left:1px solid var(--border)}
#sidebar .logo{padding:20px 20px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}
#sidebar .logo-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--green),#0066FF);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
#sidebar .logo-text{font-size:20px;font-weight:800;letter-spacing:-0.5px}
#sidebar .logo-text span{color:var(--green)}
#sidebar nav{flex:1;padding:16px 10px;display:flex;flex-direction:column;gap:4px;overflow-y:auto}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:12px;cursor:pointer;transition:.2s;font-size:14px;color:var(--muted)}
.nav-item:hover{background:rgba(255,255,255,.05);color:var(--text)}
.nav-item.active{background:rgba(0,200,150,.12);color:var(--green);font-weight:600}
.nav-item .ni{font-size:18px;flex-shrink:0}
.nav-item .badge{margin-left:auto;background:var(--red);color:#fff;border-radius:10px;font-size:10px;padding:1px 6px;font-weight:700}
#sidebar .sidebar-bottom{padding:10px;border-top:1px solid var(--border);margin-top:auto}
.user-card{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.04);cursor:pointer}
.user-av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--green),#0066FF);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.user-info .name{font-size:13px;font-weight:600}
.user-info .plan{font-size:11px;color:var(--green)}

/* 主内容区 */
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
#topbar{height:56px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:12px;flex-shrink:0;background:var(--card2)}
#topbar .tb-title{font-size:14px;font-weight:700;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tb-btn{background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:10px;padding:6px 14px;font-size:13px;cursor:pointer;color:var(--text);transition:.2s;white-space:nowrap}
.tb-btn:hover{border-color:var(--green);color:var(--green)}
.tb-btn.primary{background:var(--green);color:var(--dark);border-color:var(--green);font-weight:600}
#topbar .ticker-strip{flex:1;overflow:hidden;display:flex;gap:16px;align-items:center}
.ticker-item{display:flex;align-items:center;gap:6px;font-size:12px;white-space:nowrap;color:var(--muted)}
.ticker-item .sym{color:var(--text);font-weight:600}
.ticker-item .chg{font-size:11px;padding:1px 6px;border-radius:4px}

#content{flex:1;overflow:hidden;position:relative}
.page{display:none;height:100%;overflow-y:auto;padding:20px}
.page.active{display:block}

/* ===== 通用组件 ===== */
.card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px}
.section-title{font-size:16px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between}
.section-title .sub{font-size:13px;color:var(--muted);font-weight:400}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:8px 16px;border-radius:10px;font-size:13px;cursor:pointer;transition:.2s;border:none;font-family:inherit}
.btn-primary{background:var(--green);color:var(--dark);font-weight:600}
.btn-primary:hover{opacity:.9}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text)}
.btn-outline:hover{border-color:var(--green);color:var(--green)}
.btn-danger{background:rgba(255,75,110,.15);color:var(--red);border:1px solid rgba(255,75,110,.3)}
.tag{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:12px}
.tag-green{background:rgba(0,200,150,.12);color:var(--green);border:1px solid rgba(0,200,150,.3)}
.tag-red{background:rgba(255,75,110,.12);color:var(--red);border:1px solid rgba(255,75,110,.3)}
.tag-yellow{background:rgba(255,184,0,.12);color:var(--yellow);border:1px solid rgba(255,184,0,.3)}
.tag-blue{background:rgba(59,130,246,.12);color:var(--blue);border:1px solid rgba(59,130,246,.3)}
.up{color:var(--green)} .down{color:var(--red)}
.muted{color:var(--muted)}

/* ===== 仪表盘 ===== */
.dashboard-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:20px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;position:relative;overflow:hidden}
.stat-card::after{content:'';position:absolute;right:-10px;top:-10px;width:80px;height:80px;border-radius:50%;opacity:.06}
.stat-card.s-green::after{background:var(--green)}
.stat-card.s-red::after{background:var(--red)}
.stat-card.s-yellow::after{background:var(--yellow)}
.stat-card.s-blue::after{background:var(--blue)}
.stat-label{font-size:12px;color:var(--muted);margin-bottom:8px}
.stat-val{font-size:28px;font-weight:800;letter-spacing:-1px;margin-bottom:6px}
.stat-change{font-size:12px;display:flex;align-items:center;gap:4px}

/* K线图容器 */
.chart-wrap{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-bottom:20px}
.chart-header{padding:16px 20px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px}
.chart-symbol{font-size:18px;font-weight:700}
.chart-price{font-size:24px;font-weight:800;color:var(--green)}
.chart-change{font-size:13px}
.chart-intervals{display:flex;gap:4px;margin-left:auto}
.iv-btn{padding:4px 10px;border-radius:8px;font-size:12px;cursor:pointer;color:var(--muted);transition:.2s}
.iv-btn.active,.iv-btn:hover{background:rgba(0,200,150,.15);color:var(--green)}
#kline-container{height:380px;width:100%}

/* 两栏布局 */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}

/* ===== 行情列表 ===== */
.market-tabs{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap}
.mkt-tab{padding:6px 16px;border-radius:20px;font-size:13px;cursor:pointer;background:var(--card);border:1px solid var(--border);color:var(--muted);transition:.2s;white-space:nowrap}
.mkt-tab.active{background:var(--green);color:var(--dark);border-color:var(--green);font-weight:600}
.price-table{width:100%;border-collapse:collapse}
.price-table th{font-size:12px;color:var(--muted);padding:8px 12px;text-align:left;border-bottom:1px solid var(--border);font-weight:500}
.price-table td{padding:12px;border-bottom:1px solid rgba(30,48,80,.5);font-size:14px;vertical-align:middle}
.price-table tr:hover td{background:rgba(255,255,255,.02);cursor:pointer}
.sym-cell{display:flex;align-items:center;gap:10px}
.sym-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.sym-name{font-weight:600;font-size:14px}
.sym-full{font-size:12px;color:var(--muted)}
.mini-bar{display:flex;align-items:flex-end;gap:1px;height:28px}
.mb{width:3px;border-radius:1px 1px 0 0;background:var(--green)}
.mb.d{background:var(--red)}

/* ===== AI 客服 ===== */
.chat-layout{display:grid;grid-template-columns:1fr 320px;gap:16px;height:calc(100vh - 195px)}
.chat-main{background:var(--card);border:1px solid var(--border);border-radius:16px;display:flex;flex-direction:column;overflow:hidden}
.chat-messages{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px}
.msg-row{display:flex;gap:10px;align-items:flex-start}
.msg-row.user{flex-direction:row-reverse}
.msg-av{width:34px;height:34px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px}
.ai-av{background:linear-gradient(135deg,var(--green),#0066FF)}
.usr-av{background:linear-gradient(135deg,#FF6B35,#FF4B6E)}
.bubble{max-width:70%;padding:12px 16px;border-radius:18px;font-size:14px;line-height:1.6}
.ai-bubble{background:var(--card2);border:1px solid var(--border);border-top-left-radius:4px}
.user-bubble{background:var(--green);color:var(--dark);font-weight:500;border-top-right-radius:4px}
.bubble .typing{display:flex;gap:4px;align-items:center;padding:4px 0}
.typing span{width:6px;height:6px;border-radius:50%;background:var(--muted);animation:bounce .8s infinite}
.typing span:nth-child(2){animation-delay:.15s}
.typing span:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}
.chat-suggestions{padding:12px 20px;display:flex;gap:8px;flex-wrap:wrap;border-top:1px solid var(--border)}
.sugg{padding:6px 14px;border-radius:20px;background:rgba(0,200,150,.1);border:1px solid rgba(0,200,150,.25);color:var(--green);font-size:12px;cursor:pointer;transition:.2s;white-space:nowrap}
.sugg:hover{background:rgba(0,200,150,.2)}
.chat-input-area{padding:14px 20px;border-top:1px solid var(--border);display:flex;gap:10px;align-items:center}
.chat-input-area input{flex:1;background:var(--card2);border:1px solid var(--border);border-radius:25px;padding:11px 18px;font-size:14px;color:var(--text);outline:none;font-family:inherit}
.chat-input-area input:focus{border-color:var(--green)}
.send-btn{width:42px;height:42px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;flex-shrink:0;border:none}
.chat-sidebar{display:flex;flex-direction:column;gap:12px;overflow-y:auto;max-height:calc(100vh - 180px)}
.order-panel{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px}
/* 宏观Banner */
#macro-banner::-webkit-scrollbar{display:none}
.macro-card{display:inline-flex;flex-direction:column;gap:2px;padding:0 16px;flex-shrink:0}
.mc-label{font-size:10px;color:#555;letter-spacing:0.5px}
.mc-val{font-size:15px;font-weight:700;color:var(--text)}
.mc-sub{font-size:10px;color:#555}
.mc-loading{color:#444;font-size:13px}
.mc-divider{width:1px;height:32px;background:rgba(255,255,255,0.06);flex-shrink:0}
/* FRED 详情卡片 */
.fred-row{display:flex;justify-content:space-between;align-items:center}
.fred-lbl{color:var(--muted);font-size:11.5px}
.fred-val{font-weight:600;font-size:12px;color:var(--text)}
.op-title{font-size:14px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:6px}
.op-row{margin-bottom:12px}
.op-label{font-size:12px;color:var(--muted);margin-bottom:6px}
.op-input{width:100%;background:var(--card2);border:1px solid var(--border);border-radius:10px;padding:9px 12px;font-size:14px;color:var(--text);outline:none}
.op-input:focus{border-color:var(--green)}
.dir-btns{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.dir-btn{padding:10px;border-radius:10px;text-align:center;font-size:13px;font-weight:600;cursor:pointer;border:2px solid transparent;transition:.2s}
.dir-btn.buy{background:rgba(0,200,150,.12);color:var(--green);border-color:rgba(0,200,150,.3)}
.dir-btn.buy.sel,.dir-btn.buy:hover{background:var(--green);color:var(--dark);border-color:var(--green)}
.dir-btn.sell{background:rgba(255,75,110,.12);color:var(--red);border-color:rgba(255,75,110,.3)}
.dir-btn.sell.sel,.dir-btn.sell:hover{background:var(--red);color:#fff;border-color:var(--red)}

/* ===== 持仓 ===== */
.pos-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px;margin-bottom:12px;border-left:4px solid var(--green)}
.pos-card.short{border-left-color:var(--red)}
.pos-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.pos-sym{font-size:18px;font-weight:700}
.pos-dir-badge{font-size:11px;padding:3px 10px;border-radius:6px;font-weight:600;margin-left:8px}
.pos-pnl{font-size:22px;font-weight:800;color:var(--green);text-align:right}
.pos-pnl.neg{color:var(--red)}
.pos-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.pos-item .lbl{font-size:11px;color:var(--muted);margin-bottom:3px}
.pos-item .val{font-size:13px;font-weight:600}
.pos-actions{display:flex;gap:8px}
.pos-pnl-bar{height:4px;border-radius:4px;background:var(--border);margin-bottom:14px;overflow:hidden}
.pos-pnl-fill{height:100%;border-radius:4px;background:var(--green);transition:width .5s}
.pos-pnl-fill.neg{background:var(--red)}

/* ===== 我的/账户 ===== */
.profile-hero{background:linear-gradient(135deg,#0D2545,#1a2f50);border:1px solid var(--border);border-radius:20px;padding:24px;margin-bottom:20px;display:flex;align-items:center;gap:20px}
.profile-av{width:72px;height:72px;border-radius:20px;background:linear-gradient(135deg,var(--green),#0066FF);display:flex;align-items:center;justify-content:center;font-size:32px;flex-shrink:0}
.profile-info .name{font-size:22px;font-weight:800;margin-bottom:4px}
.profile-info .plan-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(0,200,150,.12);border:1px solid rgba(0,200,150,.3);color:var(--green);border-radius:20px;padding:4px 12px;font-size:13px;font-weight:600}
.profile-stats{display:flex;gap:24px;margin-top:14px}
.ps-item .lbl{font-size:11px;color:var(--muted)}
.ps-item .val{font-size:16px;font-weight:700}
.broker-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:10px;display:flex;align-items:center;gap:14px}
.broker-icon{width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.broker-info{flex:1}
.broker-name{font-size:15px;font-weight:600;margin-bottom:3px}
.broker-bal{color:var(--green);font-size:14px;font-weight:600}
.broker-status{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:4px;margin-top:2px}
.dot-live{width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block}
.dot-off{width:6px;height:6px;border-radius:50%;background:var(--muted);display:inline-block}
.add-broker{background:rgba(255,255,255,.03);border:2px dashed var(--border);border-radius:14px;padding:20px;text-align:center;color:var(--muted);cursor:pointer;margin-bottom:10px;transition:.2s}
.add-broker:hover{border-color:var(--green);color:var(--green)}
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid rgba(30,48,80,.6);font-size:14px}
.settings-row:last-child{border-bottom:none}
.settings-row .lbl{color:var(--muted);font-size:13px}
.toggle{width:44px;height:24px;border-radius:12px;background:var(--border);position:relative;cursor:pointer;transition:.3s;flex-shrink:0}
.toggle.on{background:var(--green)}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:.3s}
.toggle.on::after{left:23px}
/* 订阅卡片 */
.plan-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px}
.plan-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;text-align:center;cursor:pointer;transition:.2s;position:relative}
.plan-card.current{border-color:var(--green);background:rgba(0,200,150,.05)}
.plan-card.popular{border-color:var(--purple)}
.plan-badge{position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:var(--purple);color:#fff;border-radius:10px;padding:2px 10px;font-size:11px;font-weight:600;white-space:nowrap}
.plan-name{font-size:15px;font-weight:700;margin-bottom:6px}
.plan-price{font-size:26px;font-weight:800;margin-bottom:4px}
.plan-price span{font-size:14px;font-weight:400;color:var(--muted)}
.plan-features{list-style:none;text-align:left;margin-top:12px;display:flex;flex-direction:column;gap:6px}
.plan-features li{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:6px}
.plan-features li.ok{color:var(--text)}
.plan-features li::before{content:'✓';color:var(--green);font-weight:700;flex-shrink:0}
.plan-features li.no::before{content:'✗';color:var(--muted)}

/* ===== 策略页 ===== */
.strategy-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.strat-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;cursor:pointer;transition:.2s}
.strat-card:hover{border-color:rgba(0,200,150,.4);transform:translateY(-2px)}
.strat-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px}
.strat-name{font-size:15px;font-weight:700}
.strat-status{font-size:11px;display:flex;align-items:center;gap:4px}
.strat-metrics{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:14px}
.sm-item .lbl{font-size:11px;color:var(--muted);margin-bottom:2px}
.sm-item .val{font-size:14px;font-weight:700}
.strat-footer{display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid var(--border)}
.strat-tags{display:flex;gap:6px}
.strat-controls{display:flex;gap:6px}
.ctrl-btn{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;border:none;transition:.2s}
.ctrl-run{background:rgba(0,200,150,.12);color:var(--green)}
.ctrl-pause{background:rgba(255,184,0,.12);color:var(--yellow)}
.ctrl-del{background:rgba(255,75,110,.12);color:var(--red)}
.ctrl-btn:hover{opacity:.8}
/* Perf 图 */
.perf-sparkline{height:40px;display:flex;align-items:flex-end;gap:2px;padding:4px 0}
.ps-bar{flex:1;border-radius:2px 2px 0 0;min-height:2px;background:var(--green);opacity:.7}
.ps-bar.d{background:var(--red)}

/* ===== 回测页 ===== */
.backtest-form{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px;margin-bottom:20px}
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:16px}
.form-group label{display:block;font-size:12px;color:var(--muted);margin-bottom:6px}
.form-group input,.form-group select{width:100%;background:var(--card2);border:1px solid var(--border);border-radius:10px;padding:9px 12px;font-size:14px;color:var(--text);outline:none;font-family:inherit}
.form-group input:focus,.form-group select:focus{border-color:var(--green)}
.backtest-result{display:none}
.backtest-result.show{display:block}
.result-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:20px}
.rs-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px;text-align:center}
.rs-label{font-size:12px;color:var(--muted);margin-bottom:6px}
.rs-val{font-size:22px;font-weight:800}
#bt-chart{height:300px;background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-bottom:20px}
.trade-log{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.trade-log-header{padding:14px 16px;border-bottom:1px solid var(--border);font-size:14px;font-weight:600}
.trade-log-row{display:flex;align-items:center;padding:10px 16px;border-bottom:1px solid rgba(30,48,80,.4);font-size:13px}
.trade-log-row:last-child{border-bottom:none}
.trade-log-row.buy .dir{color:var(--green)}
.trade-log-row.sell .dir{color:var(--red)}
.dir{width:36px;font-size:11px;font-weight:700}
.trade-col{flex:1;color:var(--muted)}
.trade-col.val{color:var(--text)}
/* ===== 账户交易日志 ===== */
.tlog-filter-btn{padding:4px 12px;border-radius:20px;font-size:12px;cursor:pointer;background:var(--card);border:1px solid var(--border);color:var(--muted);transition:.2s;white-space:nowrap}
.tlog-filter-btn:hover,.tlog-filter-btn.active{background:var(--green);color:var(--dark);border-color:var(--green);font-weight:600}
.tlog-summary{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:16px}
.tls-item{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;text-align:center}
.tls-lbl{font-size:11px;color:var(--muted);margin-bottom:4px}
.tls-val{font-size:16px;font-weight:700}
.tlog-head{display:grid;grid-template-columns:1.4fr 1fr .6fr .9fr .9fr .6fr .8fr .7fr;padding:10px 16px;background:var(--card2);border-bottom:1px solid var(--border);font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.tlog-row{display:grid;grid-template-columns:1.4fr 1fr .6fr .9fr .9fr .6fr .8fr .7fr;padding:11px 16px;border-bottom:1px solid rgba(30,48,80,.35);font-size:13px;transition:background .15s}
.tlog-row:hover{background:rgba(255,255,255,.02)}
.tlog-row:last-child{border-bottom:none}
.tlog-dir-buy{color:var(--green);font-weight:700;font-size:11px}
.tlog-dir-sell{color:var(--red);font-weight:700;font-size:11px}
.tlog-pnl-up{color:var(--green);font-weight:600}
.tlog-pnl-down{color:var(--red);font-weight:600}
.tlog-muted{color:var(--muted)}
@media(max-width:768px){
  .tlog-summary{grid-template-columns:repeat(3,1fr)}
  .tlog-head{grid-template-columns:1.2fr .8fr .5fr .8fr .8fr .7fr;font-size:10px}
  .tlog-head span:nth-child(7),.tlog-head span:nth-child(8){display:none}
  .tlog-row{grid-template-columns:1.2fr .8fr .5fr .8fr .8fr .7fr;font-size:12px}
  .tlog-row>span:nth-child(7),.tlog-row>span:nth-child(8){display:none}
}
.trade-col.pnl{font-weight:700}

/* ===== 复制交易 ===== */
.copy-trader-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px 20px;display:flex;align-items:center;gap:16px;transition:.2s}
.copy-trader-card:hover{border-color:var(--green);transform:translateY(-1px)}
.copy-av{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--green),var(--blue));display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.copy-info{flex:1;min-width:0}
.copy-name{font-weight:700;font-size:15px;margin-bottom:2px}
.copy-tag{font-size:11px;color:var(--muted)}
.copy-stats{display:flex;gap:20px;margin-top:10px;flex-wrap:wrap}
.copy-stat{text-align:center}
.copy-stat-val{font-size:15px;font-weight:700}
.copy-stat-lbl{font-size:11px;color:var(--muted);margin-top:2px}
.copy-actions{display:flex;flex-direction:column;gap:8px;flex-shrink:0}
.my-follow-card{background:var(--card);border:1px solid var(--green);border-radius:14px;padding:14px 18px;display:flex;align-items:center;gap:14px}
.mfc-info{flex:1}
.mfc-name{font-weight:700;font-size:14px}
.mfc-pnl{font-size:13px;margin-top:2px}
.mfc-ratio{font-size:12px;color:var(--muted);margin-top:2px}
/* 跟单弹窗 */
.copy-modal{max-width:420px}

/* ===== 自动建仓 ===== */
.elite-badge{background:linear-gradient(90deg,#f59e0b,#ef4444);color:#fff;border-radius:8px;padding:2px 10px;font-size:11px;font-weight:700;margin-left:8px;vertical-align:middle}
.elite-lock-banner{background:linear-gradient(135deg,rgba(245,158,11,.08),rgba(239,68,68,.08));border:1px solid rgba(245,158,11,.4);border-radius:16px;padding:20px 24px;display:flex;align-items:center;gap:16px;margin:16px 0}
.elb-icon{font-size:32px;flex-shrink:0}
.elb-title{font-weight:700;font-size:15px;color:#f59e0b}
.elb-desc{font-size:13px;color:var(--muted);margin-top:4px}
.ao-mode-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:16px 0}
.ao-mode-card{background:var(--card);border:2px solid var(--border);border-radius:16px;padding:20px;text-align:center;cursor:pointer;transition:.2s;position:relative}
.ao-mode-card:hover{border-color:var(--green);transform:translateY(-2px)}
.ao-mode-card.active{border-color:var(--green);background:rgba(0,200,150,.05)}
.ao-mode-card.locked{opacity:.5;cursor:not-allowed;filter:grayscale(.5)}
.ao-mode-icon{font-size:32px;margin-bottom:8px}
.ao-mode-name{font-weight:700;font-size:15px;margin-bottom:6px}
.ao-mode-desc{font-size:12px;color:var(--muted);line-height:1.5}
.ao-mode-badge{margin-top:8px;font-size:11px;color:var(--green);font-weight:600}
.ao-config-panel{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:22px;margin-top:4px}
.ao-panel{}
.ao-action-row{display:flex;align-items:center;justify-content:space-between;margin-top:16px;padding-top:14px;border-top:1px solid var(--border)}
.ao-status-off{font-size:13px;color:var(--muted)}
.ao-status-on{font-size:13px;color:var(--green);font-weight:600}
.ao-live-feed{margin-top:14px;display:flex;flex-direction:column;gap:6px}
.ao-live-item{background:rgba(0,200,150,.06);border:1px solid rgba(0,200,150,.2);border-radius:10px;padding:10px 14px;font-size:12px;display:flex;align-items:center;gap:10px;animation:fadeSlideIn .4s ease}
@keyframes fadeSlideIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
.ao-dca-progress{background:var(--card2);border-radius:12px;padding:14px;margin-top:14px}
.ao-progress-bar{height:8px;background:var(--border);border-radius:4px;overflow:hidden}
.ao-progress-fill{height:100%;background:linear-gradient(90deg,var(--green),var(--blue));border-radius:4px;transition:width .5s ease}
.ao-log-wrap{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px;min-height:120px;max-height:280px;overflow-y:auto}
.ao-log-item{font-size:12px;padding:7px 0;border-bottom:1px solid rgba(30,48,80,.3);display:flex;align-items:center;gap:10px;color:var(--muted)}
.ao-log-item:last-child{border-bottom:none}
.ao-log-item .aoli-time{color:var(--muted);flex-shrink:0;width:110px}
.ao-log-item .aoli-msg{flex:1}
.ao-log-item.aoli-buy .aoli-dir{color:var(--green);font-weight:700;font-size:11px}
.ao-log-item.aoli-sell .aoli-dir{color:var(--red);font-weight:700;font-size:11px}
.ao-log-empty{color:var(--muted);text-align:center;padding:24px;font-size:13px}
@media(max-width:768px){
  .ao-mode-grid{grid-template-columns:1fr}
  .elite-lock-banner{flex-direction:column;text-align:center}
  .copy-trader-card{flex-direction:column;align-items:flex-start}
  .copy-actions{flex-direction:row;width:100%}
}

/* ===== 排行榜 升级 ===== */
.lb-tabs{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.lb-tab{padding:6px 16px;border-radius:20px;font-size:13px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted);transition:.2s}
.lb-tab.active{background:var(--green);color:var(--dark);border-color:var(--green);font-weight:700}
.lb-rank-row{display:grid;grid-template-columns:32px 1fr auto auto auto;align-items:center;gap:10px;padding:12px 16px;background:var(--card);border-radius:12px;margin-bottom:8px;cursor:pointer;transition:.2s;border:1px solid transparent}
.lb-rank-row:hover{border-color:var(--green);transform:translateX(3px)}
.lb-rank-num{font-size:18px;font-weight:800;text-align:center}
.lb-rank-num.gold{color:#FFB800}.lb-rank-num.silver{color:#A0AEC0}.lb-rank-num.bronze{color:#C87941}
.lb-av{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--green),var(--blue));display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.lb-name-wrap{display:flex;flex-direction:column}
.lb-name{font-weight:700;font-size:14px}
.lb-meta{font-size:11px;color:var(--muted);margin-top:2px}
.lb-roi{font-size:16px;font-weight:800;min-width:64px;text-align:right}
.lb-dd{font-size:12px;color:var(--muted);min-width:52px;text-align:right}
.lb-follow-btn{font-size:11px;padding:4px 12px;min-width:64px}
/* 交易员详情侧板 */
.trader-detail-panel{position:fixed;top:0;right:-420px;width:420px;max-width:100vw;height:100%;background:var(--card);border-left:1px solid var(--border);z-index:500;transition:.3s;overflow-y:auto;padding:20px}
.trader-detail-panel.open{right:0}
.tdp-header{display:flex;align-items:center;gap:14px;margin-bottom:20px}
.tdp-av{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,var(--green),var(--purple));display:flex;align-items:center;justify-content:center;font-size:24px}
.tdp-close{margin-left:auto;cursor:pointer;font-size:22px;color:var(--muted)}
.tdp-stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.tdp-stat{background:var(--card2);border-radius:10px;padding:12px;text-align:center}
.tdp-stat-val{font-size:18px;font-weight:800}
.tdp-stat-lbl{font-size:11px;color:var(--muted);margin-top:4px}
.tdp-chart{height:160px;border-radius:10px;overflow:hidden;margin-bottom:16px}
.tdp-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:499}
.tdp-overlay.open{display:block}

/* ===== 交易广场 ===== */
.sq-composer{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:20px}
.sq-composer textarea{width:100%;background:var(--card2);border:1px solid var(--border);border-radius:10px;padding:12px;color:var(--text);font-size:14px;resize:none;min-height:80px}
.sq-composer-row{display:flex;align-items:center;gap:10px;margin-top:10px;flex-wrap:wrap}
.sq-tag-btns{display:flex;gap:6px;flex-wrap:wrap;flex:1}
.sq-tag{padding:4px 12px;border-radius:20px;font-size:12px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted)}
.sq-tag.bull{border-color:var(--green);color:var(--green)}.sq-tag.bear{border-color:var(--red);color:var(--red)}.sq-tag.neutral{border-color:var(--yellow);color:var(--yellow)}
.sq-tag.active{background:var(--green);color:var(--dark)}
.sq-post{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:12px;transition:.2s}
.sq-post:hover{border-color:rgba(0,200,150,.3)}
.sq-post-header{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.sq-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.sq-author{font-weight:700;font-size:14px}
.sq-time{font-size:11px;color:var(--muted)}
.sq-sentiment{padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;margin-left:auto}
.sq-sentiment.bull{background:rgba(0,200,150,.15);color:var(--green)}
.sq-sentiment.bear{background:rgba(255,75,110,.15);color:var(--red)}
.sq-sentiment.neutral{background:rgba(255,184,0,.15);color:var(--yellow)}
.sq-content{font-size:14px;line-height:1.6;margin-bottom:12px}
.sq-ticker{display:inline-block;background:rgba(0,200,150,.1);color:var(--green);border-radius:6px;padding:1px 8px;font-size:12px;margin-bottom:8px}
.sq-actions{display:flex;gap:16px;color:var(--muted);font-size:13px}
.sq-action{cursor:pointer;display:flex;align-items:center;gap:4px;transition:.2s}
.sq-action:hover{color:var(--green)}
.sq-action.liked{color:var(--green)}
.sq-comment-box{margin-top:10px;padding-top:10px;border-top:1px solid var(--border);display:none}
.sq-comment-box.open{display:block}
.sq-comment-input{width:100%;background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-size:13px;margin-bottom:6px}
.sq-comments-list{display:flex;flex-direction:column;gap:6px;margin-bottom:8px;max-height:200px;overflow-y:auto}
.sq-comment-item{background:var(--card2);border-radius:8px;padding:8px 12px;font-size:13px}
.sq-comment-meta{font-size:11px;color:var(--muted);margin-bottom:3px}

/* ===== 策略市场 ===== */
.sm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.sm-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;transition:.2s;cursor:pointer}
.sm-card:hover{border-color:var(--green);transform:translateY(-2px)}
.sm-card-header{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.sm-av{width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:20px}
.sm-name{font-weight:700;font-size:15px}
.sm-author{font-size:12px;color:var(--muted);margin-top:2px}
.sm-perf{display:flex;gap:14px;margin-bottom:12px}
.sm-perf-item{text-align:center}
.sm-perf-val{font-size:16px;font-weight:800}
.sm-perf-lbl{font-size:11px;color:var(--muted)}
.sm-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
.sm-tag{padding:2px 10px;border-radius:20px;font-size:11px;background:rgba(59,130,246,.12);color:var(--blue)}
.sm-price{font-size:13px;font-weight:700}
.sm-price.free{color:var(--green)}
.sm-price.paid{color:var(--yellow)}
.sm-actions{display:flex;gap:8px;margin-top:12px}
.sm-upload-panel{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px;margin-bottom:24px}
.sm-upload-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}

/* ===== 信号广播 ===== */
.sig-composer{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:20px}
.sig-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.sig-signal-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;margin-bottom:10px;transition:.2s}
.sig-signal-card:hover{border-color:rgba(0,200,150,.3)}
.sig-signal-header{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.sig-direction{padding:2px 12px;border-radius:20px;font-size:12px;font-weight:700}
.sig-direction.buy{background:rgba(0,200,150,.15);color:var(--green)}
.sig-direction.sell{background:rgba(255,75,110,.15);color:var(--red)}
.sig-pair{font-weight:700;font-size:15px}
.sig-meta{font-size:12px;color:var(--muted)}
.sig-prices{display:flex;gap:16px;font-size:13px;margin-bottom:8px}
.sig-price-item{display:flex;flex-direction:column}
.sig-price-lbl{font-size:11px;color:var(--muted)}
.sig-price-val{font-weight:700}
.sig-footer{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--muted)}
.sig-status{padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700}
.sig-status.active{background:rgba(0,200,150,.15);color:var(--green)}
.sig-status.closed{background:rgba(107,141,176,.12);color:var(--muted)}
.sig-status.pending{background:rgba(255,184,0,.15);color:var(--yellow)}
.sig-sub-btn{margin-left:auto}
.sig-broadcaster-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:14px;margin-bottom:10px;transition:.2s}
.sig-broadcaster-card:hover{border-color:var(--green)}
.sig-bc-av{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--red),var(--purple));display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.sig-bc-info{flex:1}
.sig-bc-name{font-weight:700;font-size:14px}
.sig-bc-meta{font-size:12px;color:var(--muted);margin-top:2px}
.sig-bc-stats{display:flex;gap:14px;margin-top:6px}

/* ===== 底部移动导航 ===== */
#mobile-nav{display:none;position:fixed;bottom:0;left:0;right:0;height:var(--nav-h);background:rgba(10,22,40,.96);backdrop-filter:blur(20px);border-top:1px solid var(--border);z-index:200}
.mob-nav-inner{display:flex;height:100%;padding-bottom:env(safe-area-inset-bottom)}
.mob-nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;transition:.2s;color:var(--muted)}
.mob-nav-item .icon{font-size:22px;transition:.2s}
.mob-nav-item .lbl{font-size:10px;transition:.2s}
.mob-nav-item.active{color:var(--green)}
.mob-nav-item.active .icon{filter:drop-shadow(0 0 6px var(--green))}

/* ===== 顶部Hamburger ===== */
#hamburger{display:none;width:40px;height:40px;align-items:center;justify-content:center;cursor:pointer;font-size:22px;flex-shrink:0}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:150}
.sidebar-overlay.show{display:block}

/* ===== 响应式 ===== */
@media(max-width:1100px){
  .two-col{grid-template-columns:1fr}
  .chat-layout{grid-template-columns:1fr;height:auto}
  .chat-sidebar{display:none}
}
@media(max-width:768px){
  /* LTR: 侧边栏从左侧滑入 */
  #sidebar{position:fixed;top:0;left:0;width:var(--sidebar);height:100vh;transform:translateX(-100%);transition:transform .3s;z-index:200}
  #sidebar.open{transform:translateX(0)}
  /* RTL (阿拉伯语): 侧边栏从右侧滑入 */
  [dir=rtl] #sidebar{left:auto;right:0;transform:translateX(100%)}
  [dir=rtl] #sidebar.open{transform:translateX(0)}
  #hamburger{display:flex}
  .sidebar-overlay{display:none}
  .sidebar-overlay.show{display:block}
  #mobile-nav{display:block}
  #main{padding-bottom:var(--nav-h)}
  .page{padding:14px}
  .dashboard-grid{grid-template-columns:1fr 1fr}
  .stat-val{font-size:22px}
  #kline-container{height:280px}
  .three-col{grid-template-columns:1fr 1fr}
  .pos-grid{grid-template-columns:repeat(2,1fr)}
  .plan-grid{grid-template-columns:1fr 1fr}
  #topbar .ticker-strip{display:none}
}
@media(max-width:480px){
  .dashboard-grid{grid-template-columns:1fr}
  .three-col{grid-template-columns:1fr}
  .pos-grid{grid-template-columns:repeat(2,1fr)}
  .plan-grid{grid-template-columns:1fr}
  .profile-stats{flex-wrap:wrap;gap:14px}
}
/* 折叠屏适配 */
@media(min-width:580px) and (max-width:900px){
  .dashboard-grid{grid-template-columns:repeat(2,1fr)}
  .strategy-grid{grid-template-columns:1fr 1fr}
}
/* 大屏桌面 */
@media(min-width:1400px){
  .dashboard-grid{grid-template-columns:repeat(4,1fr)}
  .strategy-grid{grid-template-columns:repeat(3,1fr)}
}

/* 模态框 */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.modal-overlay.show{display:flex}
.modal{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px;max-width:460px;width:90%;max-height:90vh;overflow-y:auto}
.modal-title{font-size:18px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between}
.modal-close{cursor:pointer;color:var(--muted);font-size:20px;line-height:1}
.modal-close:hover{color:var(--text)}

/* 通知Toast */
#toast{position:fixed;top:20px;right:20px;z-index:999;display:flex;flex-direction:column;gap:8px}
.toast-item{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px 16px;font-size:13px;display:flex;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,.4);animation:slideIn .3s ease;max-width:320px}
.toast-item.success{border-color:rgba(0,200,150,.4)}
.toast-item.error{border-color:rgba(255,75,110,.4)}
@keyframes slideIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}

/* 加载动画 */
.spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}

/* 语言选择 */
.lang-btn{background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:8px;padding:5px 10px;font-size:12px;cursor:pointer;color:var(--text)}
</style>
</head>
