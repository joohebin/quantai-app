// 更新 MARKET_DATA 里的价格并刷新 UI
function applyLivePrice(sym, price, chgPct){
  const d = MARKET_DATA.find(x=>x.sym===sym);
  if(!d) return;
  if(price && price>0) d.price = price;
  if(chgPct !== undefined) d.chg = chgPct;
  d._live = true;
}

// --- Binance WebSocket ---
function startBinanceWS(){
  const streams = Object.values(BINANCE_MAP).map(s=>s+'@miniTicker').join('/');
  try{
    _binanceWs = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${streams}`);
    _binanceWs.onopen = ()=>{ setDsStatus('binance','ok','LIVE'); };
    _binanceWs.onmessage = (e)=>{
      try{
        const msg = JSON.parse(e.data);
        const tk = msg.data;
        if(!tk) return;
        const sym = Object.keys(BINANCE_MAP).find(k=>BINANCE_MAP[k]===tk.s.toLowerCase());
        if(!sym) return;
        const price = parseFloat(tk.c);
        const chgPct = ((parseFloat(tk.c)-parseFloat(tk.o))/parseFloat(tk.o)*100);
        applyLivePrice(sym, price, parseFloat(chgPct.toFixed(2)));
        updateDsLastUpdate();
      }catch(err){}
    };
    _binanceWs.onerror = ()=>{ _binanceWs=null; setDsStatus('binance','err','disconnected'); };
    _binanceWs.onclose = ()=>{ setDsStatus('binance','warn','reconnecting…'); setTimeout(startBinanceWS, 5000); };
  }catch(err){ setDsStatus('binance','err','blocked'); }
}

// --- Yahoo Finance 轮询 ---
async function fetchYahooQuotes(){
  const tickers = Object.values(YF_MAP).join(',');
  setDsStatus('yahoo','warn','fetching…');
  try{
    const res = await fetch(`${YAHOO_PROXY2}${encodeURIComponent(tickers)}&fields=regularMarketPrice,regularMarketChangePercent`, {
      headers:{'Accept':'application/json'},
      signal: AbortSignal.timeout(8000),
    });
    if(!res.ok){ setDsStatus('yahoo','err',`HTTP ${res.status}`); return; }
    const json = await res.json();
    const results = json?.quoteResponse?.result || [];
    let hitCount = 0;
    results.forEach(q=>{
      const sym = Object.keys(YF_MAP).find(k=>YF_MAP[k]===q.symbol);
      if(!sym) return;
      const price = q.regularMarketPrice;
      const chg = q.regularMarketChangePercent;
      if(price && price>0){
        applyLivePrice(sym, price, parseFloat((chg||0).toFixed(2)));
        hitCount++;
      }
    });
    if(hitCount>0){
      setDsStatus('yahoo','ok',`LIVE · ${hitCount} symbols`);
      updateDsLastUpdate();
    } else {
      setDsStatus('yahoo','warn','no data (market closed?)');
    }
  }catch(err){
    setDsStatus('yahoo','err','unreachable (sim active)');
  }
}

