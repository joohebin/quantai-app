}


function backtestStrat(sid){
  const s = _strategies.find(x => x.id === sid);
  if(!s) return;
  toast(`&#x1F4CA; ${t('sm_bt_running')||'Running backtest for'} "${s.name}"...`, '');
  setTimeout(() => {
    const ret = (Math.random() * 30 + 10).toFixed(1);
    const dd  = (Math.random() * 10 + 2).toFixed(1);
    const wr  = (Math.random() * 20 + 60).toFixed(0);
    toast(`&#x2705; ${t('sm_bt_done')||'Backtest done'}: +${ret}% | DD ${dd}% | WR ${wr}%`, 'success');
  }, 1800);
}

function copyStrat(sid){
  const s = _strategies.find(x => x.id === sid);
  if(!s) return;
  if(s.price > 0){
    toast(`&#x1F6D2; ${t('sm_pay_redirect')||'Redirecting to payment'}: ${s.priceLbl} (${t('toast_coming_soon')||'Coming soon'})`, '');
  } else {
    _copiedStrats[s.id] = true;
    toast(`&#x2705; ${t('sm_copy_success')||'Strategy copied to your library'}!`, 'success');
  }
}

