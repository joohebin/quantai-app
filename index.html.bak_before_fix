let _smFilter = 'all';
let _smShowUpload = false;

function renderStratMarket(filterOrList){
  const container = document.getElementById('sm-list');
  if(!container) return;
  // 支持 filter 字符串 或 list 数组
  let list;
  if(Array.isArray(filterOrList)){
    list = filterOrList;
  } else {
    const filter = filterOrList || _smFilter || 'all';
    _smFilter = filter;
    if(filter === 'all') list = SM_DATA;
    else if(filter === 'hot') list = [...SM_DATA].sort((a,b) => b.users - a.users);
    else if(filter === 'free') list = SM_DATA.filter(s => s.price === 0);
    else list = SM_DATA.filter(s => s.category === filter);
  }
  if(!list || list.length === 0){
    container.innerHTML = `<div style="text-align:center;padding:40px;color:var(--muted)">${t('sm_no_data')||'No strategies'}</div>`;
    return;
  }
  container.innerHTML = list.map(s => {
    const isCopied = !!_copiedStrats[s.id];
    const priceLbl = s.price === 0 ? (t('sm_price_free')||'Free') : `$${s.price}/${t('sm_per_month')||'mo'}`;
    return `<div class="sm-card" onclick="openStratDetail('${s.id}')">
      <div class="sm-card-header">
        <div style="display:flex;gap:10px;align-items:center">
          <div class="copy-av" style="width:38px;height:38px;font-size:17px">${s.av}</div>
          <div>
            <div style="font-weight:700;font-size:14px">${s.name}</div>
            <div style="font-size:11px;color:var(--muted)">${s.author} &middot; ${s.asset}</div>
          </div>
        </div>
        <span class="sm-price-tag ${s.price===0?'free':''}">${priceLbl}</span>
      </div>
      <div class="sm-desc">${s.desc}</div>
      <div class="sm-stats">
        <div class="sm-stat"><span class="up" style="font-weight:700">${s.returns}</span><span>${t('sm_stat_monthly')||'Monthly'}</span></div>
        <div class="sm-stat"><span style="font-weight:700">${s.wr}%</span><span>${t('sm_stat_wr')||'Win Rate'}</span></div>
        <div class="sm-stat"><span class="down" style="font-weight:700">${s.dd}</span><span>${t('sm_stat_dd')||'Drawdown'}</span></div>
        <div class="sm-stat"><span style="font-weight:700">${s.users}</span><span>${t('sm_stat_users')||'Users'}</span></div>
      </div>
      <div style="display:flex;gap:8px;margin-top:10px" onclick="event.stopPropagation()">
        <button class="btn btn-outline" style="font-size:12px;padding:4px 10px" onclick="backtestStrat('${s.id}')">&#x1F4CA; ${t('sm_backtest')||'Backtest'}</button>
        <button class="btn ${isCopied?'btn-outline':'btn-primary'}" style="font-size:12px;padding:4px 12px;flex:1" onclick="copyStrat('${s.id}')">
          ${isCopied ? `&#x2713; ${t('sm_copied')||'Copied'}` : (s.price===0 ? `&#x2B07; ${t('sm_free_copy')||'Free Copy'}` : `&#x1F6D2; ${t('sm_subscribe')||'Subscribe'} ${priceLbl}`)}
        </button>
      </div>
    </div>`;
  }).join('');
}


function filterStratMarket(filter){
