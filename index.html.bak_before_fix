function submitStrategy(){
  const name    = document.getElementById('sm-strat-name')?.value?.trim();
  const asset   = document.getElementById('sm-strat-asset')?.value?.trim();
  const price   = parseFloat(document.getElementById('sm-strat-price')?.value || 0);
  const code    = document.getElementById('sm-strat-code')?.value?.trim();
  if(!name || name.length < 4){ toast(t('sm_name_min')||'Strategy name must be at least 4 chars', 'warn'); return; }
  if(!code || code.length < 20){ toast(t('sm_code_min')||'Code must be at least 20 chars', 'warn'); return; }
  const newStrat = {
    id: 'st' + Date.now(), name, author: t('sq_me')||'Me', av: '✨',
    category: 'quant', asset: asset || 'BTC/USDT',
    price, priceLbl: price === 0 ? (t('sm_price_free')||'Free') : '$' + price + '/' + (t('sm_per_month')||'mo'),
    returns: '--', dd: '--', trades: 0, users: 0, rating: 5.0,
    desc: code.slice(0, 100) + '...', tags: [asset||'BTC', price===0?(t('sm_price_free')||'Free'):(t('sm_paid')||'Paid')]
  };
  _strategies.unshift(newStrat);
  toggleSmUpload();
  renderStratMarket(_smFilter);
  toast('&#x1F389; ' + (t('sm_submitted')||'Strategy submitted for review!'), 'success');
}

