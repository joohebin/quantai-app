// ===== K线数据层 =====
// Binance interval 映射
const BINANCE_INTERVAL_MAP = {'1m':'1m','5m':'5m','15m':'15m','1h':'1h','4h':'4h','1d':'1d'};
// sym → Binance K线 symbol（仅加密）
const KLINE_BINANCE_SYM = {
  'BTC/USDT':'BTCUSDT','ETH/USDT':'ETHUSDT',
  'SOL/USDT':'SOLUSDT','BNB/USDT':'BNBUSDT','XRP/USDT':'XRPUSDT',
};
// 传统品种交易时段（UTC，週一~週五）
