// 从 Binance REST 拉历史K线
async function fetchBinanceKline(sym, interval){
  const bSym = KLINE_BINANCE_SYM[sym];
  const bIv  = BINANCE_INTERVAL_MAP[interval]||'1m';
  const limit = 200;
  try{
    const res = await fetch(
      `https://api.binance.com/api/v3/klines?symbol=${bSym}&interval=${bIv}&limit=${limit}`,
      {signal: AbortSignal.timeout(8000)}
    );
    if(!res.ok) return null;
    const raw = await res.json();
    const data=[], volData=[];
    raw.forEach(k=>{
      const t = Math.floor(k[0]/1000);
      const o=parseFloat(k[1]),h=parseFloat(k[2]),l=parseFloat(k[3]),c=parseFloat(k[4]);
      const v=parseFloat(k[5]);
      const isUp = c>=o;
      data.push({time:t, open:+o.toFixed(2), high:+h.toFixed(2), low:+l.toFixed(2), close:+c.toFixed(2)});
      volData.push({time:t, value:v, color: isUp?'rgba(0,200,150,.4)':'rgba(255,75,110,.4)'});
    });
    return {data, volData, openPrice: data[0]?.open||0, lastClose: data[data.length-1]?.close||0};
  }catch(e){ return null; }
}

// 开启 Binance K线 WebSocket 实时更新（最新一根蜡烛）
function startBinanceKlineWS(sym, interval){
  stopKlineStreams();
  const bSym = KLINE_BINANCE_SYM[sym].toLowerCase();
  const bIv  = BINANCE_INTERVAL_MAP[interval]||'1m';
  let _openPrice = 0;
  try{
    _klineWs = new WebSocket(`wss://stream.binance.com:9443/ws/${bSym}@kline_${bIv}`);
    _klineWs.onmessage = (e)=>{
      try{
        const msg = JSON.parse(e.data);
        const k = msg.k;
        if(!k) return;
        const t = Math.floor(k.t/1000);
        const o=parseFloat(k.o),h=parseFloat(k.h),l=parseFloat(k.l),c=parseFloat(k.c),v=parseFloat(k.v);
        if(_openPrice===0) _openPrice=o;
        candleSeries.update({time:t,open:+o.toFixed(2),high:+h.toFixed(2),low:+l.toFixed(2),close:+c.toFixed(2)});
        volumeSeries.update({time:t,value:v,color:c>=o?'rgba(0,200,150,.4)':'rgba(255,75,110,.4)'});
        updateChartHeader(sym, c, _openPrice);
      }catch(err){}
    };
    _klineWs.onerror = ()=>{ _klineWs=null; };
    _klineWs.onclose = ()=>{
      // 断线后3s重连
      if(_currentKlineSym===sym) setTimeout(()=>startBinanceKlineWS(sym,interval),3000);
    };
  }catch(e){}
}

// 传统品种：用模拟数据，但休市时停止更新
function startTraditionalKlineSim(sym, interval){
  stopKlineStreams();
  const open = isMarketOpen(sym);
  const lbl = document.getElementById('chart-update-label');
  if(!open){
    if(lbl) lbl.innerHTML = `<span style="color:#F5A623">休市中 · K线暂停更新</span>`;
    return; // 休市直接返回，不启动定时器
  }
  if(lbl) lbl.innerHTML = `Sim · 开市模拟`;
  // 开市期间用模拟波动
  const d = MARKET_DATA.find(x=>x.sym===sym);
  let price = d ? d.price : 83000;
  const openPrice = price;
  _klineSimTimer = setInterval(()=>{
    price += price*(Math.random()-0.499)*0.001;
    const t = Math.floor(Date.now()/1000);
    const c = +price.toFixed(2);
    const range = price*0.003;
    candleSeries.update({time:t,open:+(price-range*0.3).toFixed(2),high:+(price+range).toFixed(2),low:+(price-range).toFixed(2),close:c});
    volumeSeries.update({time:t,value:Math.random()*500+100,color:c>=openPrice?'rgba(0,200,150,.4)':'rgba(255,75,110,.4)'});
    updateChartHeader(sym, price, openPrice);
  },2000);
}

// 生成初始模拟K线底座（用于传统品种）
function generateSimKlineBase(basePrice, count, intervalSecs){
  const data=[], volData=[];
  let price = basePrice;
  const now = Math.floor(Date.now()/1000);
  for(let i=count;i>=0;i--){
    const t = now - i*intervalSecs;
    const o=price;
    const change=(Math.random()-0.48)*price*0.004;
    const h=o+Math.abs(change)*1.2+price*0.001;
    const l=o-Math.abs(change)*0.8-price*0.001;
    const c=o+change;
    price=c;
    const isUp=c>=o;
    data.push({time:t,open:+o.toFixed(2),high:+h.toFixed(2),low:+l.toFixed(2),close:+c.toFixed(2)});
    volData.push({time:t,value:Math.random()*500+100,color:isUp?'rgba(0,200,150,.4)':'rgba(255,75,110,.4)'});
  }
  return {data, volData, openPrice:data[0]?.open||basePrice, lastClose:price};
}

// 主入口：加载指定品种+周期的K线
async function loadKline(sym, interval){
  sym = sym || _currentKlineSym;
  interval = interval || _currentKlineIv;
  _currentKlineSym = sym;
  _currentKlineIv  = interval;
  stopKlineStreams();

  // 更新图表标题
  document.querySelector('.chart-symbol').textContent = sym;
  const ivSecs = {'1m':60,'5m':300,'15m':900,'1h':3600,'4h':14400,'1d':86400}[interval]||60;

  if(KLINE_BINANCE_SYM[sym]){
    // === 加密货币：拉 Binance 真实历史K线 ===
    const lbl = document.getElementById('chart-update-label');
    if(lbl) lbl.innerHTML = `Binance · 加载中…`;
    const result = await fetchBinanceKline(sym, interval);
    if(result && result.data.length>0){
      candleSeries.setData(result.data);
      volumeSeries.setData(result.volData);
      updateChartHeader(sym, result.lastClose, result.openPrice);
      startBinanceKlineWS(sym, interval); // 接 WS 实时更新
    } else {
      // Binance 拉取失败，降级模拟
      const d = MARKET_DATA.find(x=>x.sym===sym);
      const bp = d ? d.price : 83000;
      const base = generateSimKlineBase(bp, 200, ivSecs);
      candleSeries.setData(base.data);
      volumeSeries.setData(base.volData);
      if(lbl) lbl.innerHTML = `<span style="color:#F5A623">Binance 不可达 · 模拟数据</span>`;
    }
  } else {
    // === 传统品种：模拟底座 + 休市判断 ===
    const d = MARKET_DATA.find(x=>x.sym===sym);
    const bp = d ? d.price : 83000;
    const base = generateSimKlineBase(bp, 200, ivSecs);
    candleSeries.setData(base.data);
    volumeSeries.setData(base.volData);
    updateChartHeader(sym, base.lastClose, base.openPrice);
    startTraditionalKlineSim(sym, interval);
  }
}

