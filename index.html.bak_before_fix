// 主函数：拉所有 FRED 数据并填入页面
async function fetchFredMacro(){
  const dot  = document.getElementById('fred-status-dot');
  const stxt = document.getElementById('fred-status-txt');
  if(dot)  dot.style.background  = '#F5A623';
  if(stxt) stxt.textContent = 'loading…';

  let successCount = 0;

  // 静态默认值（万一网络完全不通，显示上一次已知值）
  const DEFAULTS = {
    fedfunds: '5.33%', t10y: '4.25%', t2y: '4.59%',
    cpi: '3.2%', pce: '2.8%', payroll: '+256K', unrate: '3.9%', gdp: '3.4%',
  };

  // 1. 联邦基准利率 (FEDFUNDS 月度)
  const ff = await _fredGet('FEDFUNDS', 2);
  if(ff && ff[0]){
    const val = parseFloat(ff[0].value);
    const prev = ff[1] ? parseFloat(ff[1].value) : val;
    const cls = val >= prev ? 'up' : 'down';
    const arrow = val > prev ? '▲' : val < prev ? '▼' : '—';
    const disp = `${val.toFixed(2)}%`;
    setMcCard('fedfunds', disp, `${arrow} vs ${prev.toFixed(2)}% prev`, cls);
    setFredRow('fr-fedfunds', disp, cls);
    successCount++;
  } else {
    setMcCard('fedfunds', DEFAULTS.fedfunds, 'last known', '');
    setFredRow('fr-fedfunds', DEFAULTS.fedfunds, '');
  }

  // 2. 10年期美债 (DGS10 日度)
  const t10 = await _fredGet('DGS10', 2);
  if(t10 && t10[0]){
    const val = parseFloat(t10[0].value);
    const prev = t10[1] ? parseFloat(t10[1].value) : val;
    const cls = val >= prev ? 'up' : 'down';
    const disp = `${val.toFixed(2)}%`;
    setMcCard('t10y', disp, `${val>prev?'▲':'▼'} ${Math.abs(val-prev).toFixed(2)}bp`, cls);
    setFredRow('fr-t10y', disp, cls);
    successCount++;

    // 2年期
    const t2 = await _fredGet('DGS2', 2);
    if(t2 && t2[0]){
      const v2 = parseFloat(t2[0].value);
      setFredRow('fr-t2y', `${v2.toFixed(2)}%`, v2 >= parseFloat(t10[0].value) ? 'down' : '');
      // 期限利差
      const spread = val - v2;
      const spCls  = spread >= 0 ? 'up' : 'down';
      setFredRow('fr-spread', `${spread>=0?'+':''}${spread.toFixed(2)}%`, spCls);
    } else {
      setFredRow('fr-t2y', DEFAULTS.t2y, '');
      setFredRow('fr-spread', '—', '');
    }
  } else {
    setMcCard('t10y', DEFAULTS.t10y, 'last known', '');
    setFredRow('fr-t10y', DEFAULTS.t10y, '');
    setFredRow('fr-t2y', DEFAULTS.t2y, '');
    setFredRow('fr-spread', '—', '');
  }

  // 3. CPI (CPIAUCSL 月度指数→计算YoY)
  const cpi = await _fredGet('CPIAUCSL', 14);
  if(cpi && cpi.length >= 13){
    const cur  = parseFloat(cpi[0].value);
    const yr   = parseFloat(cpi[12].value);
    const yoy  = ((cur-yr)/yr*100).toFixed(1);
    const prev1 = parseFloat(cpi[1].value);
    const yoyPrev = ((prev1-parseFloat(cpi[13]?.value||cpi[12].value))/parseFloat(cpi[13]?.value||cpi[12].value)*100).toFixed(1);
    const cls  = parseFloat(yoy) <= parseFloat(yoyPrev) ? 'up' : 'down'; // CPI下降是利好
    setMcCard('cpi', `${yoy}%`, `${parseFloat(yoy)<=parseFloat(yoyPrev)?'▼ cooling':'▲ hot'}`, cls);
    setFredRow('fr-cpi', `${yoy}%`, cls);
    successCount++;
  } else {
    setMcCard('cpi', DEFAULTS.cpi, 'last known', '');
    setFredRow('fr-cpi', DEFAULTS.cpi, '');
  }

  // 4. 核心PCE (PCEPILFE 月度→YoY)
  const pce = await _fredGet('PCEPILFE', 14);
  if(pce && pce.length >= 13){
    const cur = parseFloat(pce[0].value);
    const yr  = parseFloat(pce[12].value);
    const yoy = ((cur-yr)/yr*100).toFixed(1);
    const cls = parseFloat(yoy) <= 2.5 ? 'up' : 'down';
    setFredRow('fr-pce', `${yoy}%`, cls);
    successCount++;
  } else {
    setFredRow('fr-pce', DEFAULTS.pce, '');
  }

  // 5. 非农就业 (PAYEMS 月度，单位千人)
  const pay = await _fredGet('PAYEMS', 2);
  if(pay && pay.length >= 2){
    const cur  = parseFloat(pay[0].value);
    const prev = parseFloat(pay[1].value);
    const chg  = ((cur - prev)).toFixed(0); // 千人变化
    const chgK = parseInt(chg);
    const cls  = chgK >= 0 ? 'up' : 'down';
    const disp = `${chgK>=0?'+':''}${chgK}K`;
    setMcCard('payroll', disp, `${chgK>=150?'strong':'weak'} labor market`, cls);
    setFredRow('fr-payroll', disp, cls);
    successCount++;
  } else {
    setMcCard('payroll', DEFAULTS.payroll, 'last known', '');
    setFredRow('fr-payroll', DEFAULTS.payroll, '');
  }

  // 6. 失业率 (UNRATE)
  const unr = await _fredGet('UNRATE', 2);
  if(unr && unr[0]){
    const val  = parseFloat(unr[0].value);
    const prev = unr[1] ? parseFloat(unr[1].value) : val;
    const cls  = val <= prev ? 'up' : 'down';
    const disp = `${val.toFixed(1)}%`;
    setMcCard('unrate', disp, `${val<=prev?'▼ improving':'▲ rising'}`, cls);
    setFredRow('fr-unrate', disp, cls);
    successCount++;
  } else {
    setMcCard('unrate', DEFAULTS.unrate, 'last known', '');
    setFredRow('fr-unrate', DEFAULTS.unrate, '');
  }

  // 7. GDP (A191RL1Q225SBEA 季度环比)
  const gdp = await _fredGet('A191RL1Q225SBEA', 2);
  if(gdp && gdp[0]){
    const val  = parseFloat(gdp[0].value);
    const prev = gdp[1] ? parseFloat(gdp[1].value) : val;
    const cls  = val >= 0 ? 'up' : 'down';
    const disp = `${val>=0?'+':''}${val.toFixed(1)}%`;
    setMcCard('gdp', disp, `Q: ${gdp[0].date?.slice(0,7)||'latest'}`, cls);
    successCount++;
  } else {
    setMcCard('gdp', DEFAULTS.gdp, 'QoQ', '');
  }

  // 更新状态
  const updEl = document.getElementById('fred-updated');
  if(updEl){
    const now = new Date();
    updEl.textContent = `${now.toLocaleDateString('zh-CN')} FRED`;
  }
  if(dot){
    if(successCount >= 4){
      dot.style.background = '#00C896';
      dot.style.boxShadow = '0 0 5px #00C896';
      if(stxt) stxt.textContent = `LIVE · ${successCount}/7`;
    } else if(successCount > 0){
      dot.style.background = '#F5A623';
      if(stxt) stxt.textContent = `partial · ${successCount}/7`;
    } else {
      dot.style.background = '#FF4D4D';
      dot.style.boxShadow = 'none';
      if(stxt) stxt.textContent = 'offline · static data';
    }
  }

  // 同步更新 macro source 标签
  const src = document.getElementById('macro-source');
  if(src) src.textContent = successCount > 0 ? `FRED · St. Louis Fed · ${new Date().toLocaleTimeString('zh-CN',{hour:'2-digit',minute:'2-digit'})}` : 'FRED (offline · static)';
}

