// 用 allorigins CORS 代理访问 FRED
async function _fredFetch(seriesId, count){
  count = count || 2;
  const url = `https://api.stlouisfed.org/fred/series/observations?series_id=${seriesId}&api_key=39acf411b89de9d43fcb87b898d04c2f&sort_order=desc&limit=${count}&file_type=json`;
  const proxy = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
  try{
    const res = await fetch(proxy, {signal: AbortSignal.timeout(10000)});
    if(!res.ok) return null;
    const wrapper = await res.json();
    const data = JSON.parse(wrapper.contents || '{}');
    return data?.observations || null;
  }catch(e){ return null; }
}

// 直接访问 FRED（如果网络通）
async function _fredFetchDirect(seriesId, count){
  count = count || 2;
  const url = `https://api.stlouisfed.org/fred/series/observations?series_id=${seriesId}&api_key=39acf411b89de9d43fcb87b898d04c2f&sort_order=desc&limit=${count}&file_type=json`;
  try{
    const res = await fetch(url, {signal: AbortSignal.timeout(8000)});
    if(!res.ok) return null;
    const data = await res.json();
    return data?.observations || null;
  }catch(e){ return null; }
}

// 两层降级（直连 → 代理 → 静态默认值）
async function _fredGet(seriesId, count){
  let obs = await _fredFetchDirect(seriesId, count);
  if(!obs) obs = await _fredFetch(seriesId, count);
  return obs;
}

