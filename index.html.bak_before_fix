// 判断传统品种是否在交易时间（粗略判断：UTC+0 工作日且非深夜）
function isMarketOpen(sym){
  const now = new Date();
  const day = now.getUTCDay(); // 0=Sun,6=Sat
  if(day===0 || day===6) return false; // 周末一律关市
  // 简单用 UTC 时间判断纽约日盘（UTC 13:30~20:00）
  const h = now.getUTCHours(), m = now.getUTCMinutes();
  const utcMin = h*60+m;
  if(['NAS100','SPX500','DOW'].includes(sym)){
    return utcMin >= 13*60+30 && utcMin < 20*60;
  }
  // 黄金/原油几乎全天（仅周五22:00~周日22:00 UTC关市）
  return true;
}

